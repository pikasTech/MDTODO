# Dependencies - always exclude
node_modules/

# Build outputs - dist/ is bundled, but out/ contains TypeScript output needed for vsce
dist/

# Test files - exclude from package
test/
*.test.ts
*.test.tsx
jest.config.js

# Development files
.vscode/
.gitignore
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Temporary
*.tmp
*.temp
nul

# Exclude doc/ directory from package (not needed in production)
doc/

# Exclude pack.bat from package (not needed in production)
pack.bat

# ============================================
# Exclude large development files from VSIX
# ============================================

# CLI 工具目录（Python 实现，不需要打包到 VSIX）
cli/

# 文档目录（不需要打包到 VSIX）
docs/
docs-details/

# Claude 相关目录（开发配置）
.claude/

# Playwright 测试截图
.playwright-mcp/

# 安装脚本（不需要打包）
install.bat

# 其他开发文件
*.bat
*.sh
readme.md
CLAUDE.md
tsconfig.json
tsconfig.webview.json

# Webpack 配置
webpack.config.js
webpack.*.js
